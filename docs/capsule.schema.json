{
  "$defs": {
    "AgentSpec": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "required": [
        "prompt",
        "model"
      ],
      "title": "AgentSpec",
      "type": "object"
    },
    "ModelSpec": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelSpec",
      "type": "object"
    },
    "PermissionsSpec": {
      "additionalProperties": false,
      "properties": {
        "tools": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Tools",
          "type": "object"
        }
      },
      "title": "PermissionsSpec",
      "type": "object"
    },
    "ToolSpec": {
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entrypoint"
        },
        "permission": {
          "title": "Permission",
          "type": "string"
        },
        "server": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Server"
        },
        "tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool"
        },
        "type": {
          "default": "python",
          "enum": [
            "python",
            "mcp"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "permission"
      ],
      "title": "ToolSpec",
      "type": "object"
    },
    "WorkflowSpec": {
      "additionalProperties": false,
      "properties": {
        "start": {
          "title": "Start",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/WorkflowStepSpec"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "start",
        "steps"
      ],
      "title": "WorkflowSpec",
      "type": "object"
    },
    "WorkflowStepSpec": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "next": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Next"
        },
        "output": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output"
        },
        "type": {
          "default": "agent",
          "enum": [
            "agent",
            "human_gate"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "WorkflowStepSpec",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agents": {
      "additionalProperties": {
        "$ref": "#/$defs/AgentSpec"
      },
      "title": "Agents",
      "type": "object"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "input_schema": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Schema"
    },
    "models": {
      "additionalProperties": {
        "$ref": "#/$defs/ModelSpec"
      },
      "title": "Models",
      "type": "object"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "output_schema": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Schema"
    },
    "permissions": {
      "$ref": "#/$defs/PermissionsSpec"
    },
    "tests": {
      "items": {
        "type": "string"
      },
      "title": "Tests",
      "type": "array"
    },
    "tools": {
      "additionalProperties": {
        "$ref": "#/$defs/ToolSpec"
      },
      "title": "Tools",
      "type": "object"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "workflow": {
      "$ref": "#/$defs/WorkflowSpec"
    }
  },
  "required": [
    "name",
    "version",
    "models",
    "agents",
    "workflow"
  ],
  "title": "Capsule Manifest",
  "type": "object"
}
